rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{docId} {
      allow read, write: if true;
    }
    match /shipments/{docId} {
      allow read, write: if true;
    }
    match /components/{docId} {
      allow read, write: if true;
    }
    match /activity_log/{docId} {
      allow read, write: if true;
    }
    match /inventory_history/{docId} {
      allow read, write: if true;
    }
    match /system/{docId} {
      allow read, write: if true;
    }

    // Раздел «Финансы» (отгрузки, выплаты, баланс ЛК, остатки)
    match /finance_payments/{docId} {
      allow read, write: if true;
    }
    match /finance_shipments/{docId} {
      allow read, write: if true;
    }
    match /finance_balance_snapshots/{docId} {
      allow read, write: if true;
    }
    match /finance_warehouse_stock/{docId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
